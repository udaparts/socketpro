	/*
		A set of pre-defined error code (non-socket)
	*/
	enum tagUErrorCode
	{
		//Success
		uecOK = 0, 

		//Server is not regsiterred with a key
		uecSvrNotRegistered = 0x00000001, 
		
		//Programming error, usually wrong input value. 
		//For example, host address is null or zero in length.
		uecUnexpected = 0x8F000000, 

		//Service is not available at a remote server
		uecSvsNotAvailable = 0x8F100001,

		//Authentication failed at server side
		uecAuthenticationFailed=0x8F100002,

		//SocketPro server closes the socket connection
		uecClientRejected = 0x8F100003,   

		//having trouble in loading two OpenSSL libraries
		uecFailedInLoadingSSL = 0x8F100004,
		
		
		uecFailedInStartingSSL = 0x8F100005,
		
		//Method is not implemented
		uecNotImplemented = 0x8F100006,
		uecFail = 0x8F100007,
		uecFailedInZip = 0x8F100008,
		uecFailedInUnzip = 0x8F100009,
		uecFailedInEncrypt = 0x8F10000A,
		uecFailedInDecrypt = 0x8F10000B,
		
		//read only
		uecReadOnly = 0x8F10000C,

		//SocketPro server stop sending data to a client for a request
		uecNoMoreData = 0x8F10000D,

		//SocketPro catches an code running exception
		uecExceptionCatched = 0x8F10000E,

		//A request is already canceled
		uecRequestCanceled = 0x8F10000F,

		//A unknown request found at SocketPro server
		uecNotFound = 0x8F100010,

		uecFailedInLoadingMsSSPI = 0x8f100011,

		uecBadData = 0x8f100012,
		uecWrongServerVersion = 0x8f100013,
	};
	
