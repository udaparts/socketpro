	enum tagAddressFamily
	{
		afUnix		=	1,        /* local to host (pipes, portals) */
		afINet      =	2,        /* internetwork: UDP, TCP, etc. */
		afImpLink	=   3,              /* arpanet imp addresses */
		afPup		=   4,               /* pup protocols: e.g. BSP */
		afChaos		=   5,               /* mit CHAOS protocols */
		afNS		=   6,               /* XEROX NS protocols */
		afIPX       =	afNS,           /* IPX protocols: IPX, SPX, etc. */
		afISO       =   7,               /* ISO protocols */
		afOSI       =	afISO,          /* OSI is ISO */
		afECMA      =	8,               /* european computer manufacturers */
		afDataKit	=   9,               /* datakit protocols */
		afCCITT     =   10,              /* CCITT protocols, X.25 etc */
		afSNA       =   11,              /* IBM SNA */
		afDECnet    =   12,              /* DECnet */
		afDLI       =   13,              /* Direct data link interface */
		afLAT       =   14,              /* LAT */
